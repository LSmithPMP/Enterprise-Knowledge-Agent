    {
      "parameters": {
        "jsCode": "// Security signal scanner \u2014 pattern match on new corpus content\nconst items = $input.all();\nconst signals = [];\nconst patterns = {\n  cve: /CVE-\\d{4}-\\d{4,7}/gi,\n  vuln_keywords: /\\b(vulnerability|exploit|RCE|buffer overflow|injection|bypass|0-day|zero-day)\\b/gi,\n  incident_keywords: /\\b(incident|breach|compromise|unauthorized access|exfiltration)\\b/gi,\n  ot_keywords: /\\b(SCADA|PLC|HMI|ICS|OT network|CAN bus|ECU)\\b/gi\n};\nfor (const item of items) {\n  const content = JSON.stringify(item.json);\n  const found = {};\n  for (const [key, pattern] of Object.entries(patterns)) {\n    const matches = content.match(pattern);\n    if (matches) found[key] = [...new Set(matches)];\n  }\n  if (Object.keys(found).length > 0) {\n    signals.push({ doc_id: item.json.doc_id, signals: found, content_excerpt: content.slice(0, 500) });\n  }\n}\nreturn signals.length > 0 ? signals.map(s => ({ json: s })) : [{ json: { _no_signals: true } }];"
      },
      "id": "7dc0367c-65a1-4a2b-9eab-f9b96fce686a",
      "name": "3. Security Signal Scanner",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3008,
        0
      ]
    },
    {
      "parameters": {
        "url": "=https://services.nvd.nist.gov/rest/json/cves/2.0?cveId={{ ($json.signals && $json.signals.cve && $json.signals.cve[0]) || 'CVE-2024-0001' }}",
