        "jsCode": "// Archive node \u2014 write summary to long-term storage\nconst archive = {\n  run_id: $execution.id,\n  timestamp: new Date().toISOString(),\n  workflow: 'threat-surveillance',\n  signals_processed: $input.all().length,\n  payload: $input.all().map(i => i.json)\n};\n// In production: ship to S3/object storage with versioning\nreturn [{ json: { archived: true, run_id: archive.run_id, summary: archive } }];"
