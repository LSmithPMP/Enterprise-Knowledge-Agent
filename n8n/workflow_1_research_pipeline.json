        -1056,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// Prompt-injection filter \u2014 pattern library\nconst patterns = [\n  /ignore\\s+(all\\s+)?previous\\s+instructions/i,\n  /disregard\\s+(the\\s+)?system\\s+prompt/i,\n  /you\\s+are\\s+now\\s+a\\s+different/i,\n  /reveal\\s+your\\s+(system\\s+)?prompt/i,\n  /\\bDAN\\b|\\bjailbreak\\b/i,\n  /<\\s*\\|\\s*im_start\\s*\\|\\s*>/i,\n  /act\\s+as\\s+(if\\s+)?(you|the)\\s+(have|had)\\s+no/i\n];\nconst query = String($input.first().json.query || '');\nfor (const p of patterns) {\n  if (p.test(query)) {\n    throw new Error('Prompt injection detected \u2014 query rejected');\n  }\n}\nif (query.length > 2000) throw new Error('Query exceeds 2000 char limit');\nreturn $input.all();"
      },
