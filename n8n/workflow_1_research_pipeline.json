    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst webhookNode = $('1. Webhook \u2014 Inbound Query').first();\n\n// n8n captures the raw POST body as a base64 binary at .binary.data.data\nconst rawBody = webhookNode.binary && webhookNode.binary.data\n  ? Buffer.from(webhookNode.binary.data.data, 'base64').toString('utf-8')\n  : JSON.stringify(webhookNode.json.body || webhookNode.json || {});\n\n// Get signature header (n8n preserves header casing under .headers)\nconst headers = webhookNode.json.headers || {};\nconst signature = headers['x-signature'] || headers['X-Signature'] || '';\n\nconst secret = \"{{ $env.N8N_WEBHOOK_SECRET }}\";\nconst expected = crypto.createHmac('sha256', secret).update(rawBody).digest('hex');\n\nif (!signature || signature !== expected) {\n  throw new Error(`HMAC verification failed \u2014 request rejected. Expected ${expected.slice(0,8)}..., got ${(signature || 'NONE').slice(0,8)}...`);\n}\n\n// Pass parsed body forward\nconst parsedBody = JSON.parse(rawBody);\nreturn [{\n  json: {\n    ...parsedBody,\n    _verified: true,\n    _trace_id: crypto.randomUUID()\n  }\n}];"
      },
      "id": "4bee2a49-bf9a-4cef-8074-a616a24c90cd",
      "name": "2. HMAC Verify",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1504,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// API key validation\nconst apiKey = $input.first().json.api_key || '';\nconst validKey = '{{ $env.API_KEY }}';\nif (!apiKey || apiKey !== validKey) {\n  throw new Error('Invalid API key');\n}\nreturn $input.all();"
      },
      "id": "e3036078-8627-4b87-9d78-5b11f7af4db4",
      "name": "3. API Key Auth",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1280,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// API key validation \u2014 reads from the webhook's original payload regardless of upstream transforms\nconst webhookPayload = $('1. Webhook \u2014 Inbound Query').first().json.body || $('1. Webhook \u2014 Inbound Query').first().json || {};\nconst apiKey = webhookPayload.api_key || '';\nconst validKey = \"{{ $env.API_KEY }}\";\nif (!apiKey || apiKey !== validKey) {\n  throw new Error('Invalid API key');\n}\nreturn $input.all();"
      },
      "id": "3ac5e8e4-7b3f-41a4-90ed-62c0daabe8ef",
      "name": "4. Rate Limiter",
      "type": "n8n-nodes-base.code",
